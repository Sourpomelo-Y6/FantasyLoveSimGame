  heroineId: TestHeroine
  displayName: "\u30C6\u30B9\u30C8\u30D2\u30ED\u30A4\u30F3\uFF08\u30C4\u30F3\u30C7\u30EC\uFF09"
  defaultHeroineSprite: {fileID: 21300000, guid: 75760bce93a9a794498a3ef81175bafb, type: 3}
  initialDialogueMessage: "\u4F55\u3092\u8A71\u3059\u306E\uFF1F\u6687\u306A\u3089\u5C11\u3057\u3060\u3051\u76F8\u624B\u3057\u3066\u3042\u3052\u308B\u3002"
  nextActionPrompt: "\u6B21\u306F\u3069\u3046\u3059\u308B\u306E\uFF1F\u65E9\u304F\u6C7A\u3081\u306A\u3055\u3044\u3088\u3002"
  morningGreeting: "\u304A\u306F\u3088\u3046\u3002\u4ECA\u65E5\u3082\u3061\u3083\u3093\u3068\u8D77\u304D\u305F\u306E\u306D\u3002\u307E\u3042\u3001\u60AA\u304F\u306A\u3044\u308F\u3002"
  goodNightGreeting: "\u3082\u3046\u591C\u3088\u3002\u7121\u7406\u3057\u3066\u8D77\u304D\u3066\u306A\u3044\u3067\u3001\u3055\u3063\u3055\u3068\u4F11\u307F\u306A\u3055\u3044\u3002\u2026\u307E\u305F\u660E\u65E5\u3002"
  gameStartFallbackMessage: "\u3053\u3053\u304B\u3089\u3001\u3042\u3093\u305F\u3068\u306E\u751F\u6D3B\u304C\u59CB\u307E\u308B\u306E\u306D\u3002"
  gameStartFollowUpMessage: "\u305D\u308C\u3067\u3001\u4ECA\u65E5\u306F\u4F55\u3092\u8A71\u3059\u306E\uFF1F"
  outfitMessageOverrides:
  - outfitId: Normal
    lockedMessage: ""
    changedMessage: "いつもの服にしたわ。別に、あんたのために選んだわけじゃないから。"
  - outfitId: Spring
    lockedMessage: "その服はまだ早いわ。もう少し仲良くなってからにしなさいよ。"
    changedMessage: "春っぽい服にしてみただけよ。少し外を歩くくらいなら付き合ってあげてもいいわ。"
  - outfitId: Summer
    lockedMessage: "その服はまだ恥ずかしいから駄目。何を期待してるのよ。"
    changedMessage: "暑いから涼しそうな服にしたの。じろじろ見ないでよね。"
  - outfitId: Autumn
    lockedMessage: "その服はまだ見せる気になれないわ。今は別のにして。"
    changedMessage: "秋らしい色にしてみたわ。落ち着いてて悪くないでしょ。"
  - outfitId: Winter
    lockedMessage: "その服はまだ早いわ。無理に着せようとしないで。"
    changedMessage: "今日は暖かくしておくわ。寒いのは苦手なの。笑ったら怒るから。"
  - outfitId: Raincoat
    lockedMessage: "雨具くらい自分で選べるわ。まだこれは使わないから。"
    changedMessage: "雨に濡れるのは嫌だから雨具にしただけよ。あんたもちゃんと濡れないようにしなさい。"
  - outfitId: Dress
    lockedMessage: "ドレスなんて、まだ恥ずかしいに決まってるでしょ。もう少し待ちなさいよ。"
    changedMessage: "ど、どうかしら……変じゃないなら、少しくらい褒めてもいいわよ。"
  - outfitId: Room
    lockedMessage: "部屋着を見せるのはまだ無理。少しは遠慮しなさいよ。"
    changedMessage: "部屋で過ごすならこの服でいいでしょ。楽だから選んだだけよ。"
  - outfitId: Town
    lockedMessage: ""
    changedMessage: "街へ行くならこれで十分でしょ。置いていかれたくないなら早く準備しなさい。"
  - outfitId: Adventure
    lockedMessage: ""
    changedMessage: "探索するなら動きやすい服に決まってるでしょ。危ない時は、ちゃんと前に出なさいよ。"
  outfitReactionMessageOverrides:
  - reactionType: 0
    message: "べ、別に褒められて嬉しいわけじゃないけど……その、少しは見る目があるじゃない。"
  - reactionType: 1
    message: "そ、そう。気に入らないなら別の服にするわよ。……少しは言い方ってものがあるでしょ。"
  - reactionType: 2
    message: "確かに最近こればかりだったかもね。べつに、あんたに飽きられたくないとかじゃないけど。"
  - reactionType: 3
    message: "別の服にするの？ 仕方ないわね。少しくらいなら付き合ってあげる。"
  conversationResourcePath: Heroines/TestHeroine/Conversations
  gameEventResourcePath: Heroines/TestHeroine/GameEvents
  actionResourcePath: Heroines/TestHeroine/Actions
  scheduledEventResourcePath: Heroines/TestHeroine/ScheduledEvents
