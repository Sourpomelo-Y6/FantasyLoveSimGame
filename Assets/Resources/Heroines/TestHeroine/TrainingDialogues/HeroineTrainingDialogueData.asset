%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8611759c226f4c14a090efff991731bc, type: 3}
  m_Name: HeroineTrainingDialogueData
  m_EditorClassIdentifier: 
  heroineId: TestHeroine
  entries:
  - trainingId: LightPractice
    visualState: 0
    messages:
    - "べ、別にあんたの準備を待ってたわけじゃないけど……軽い練習から始めるわよ。"
  - trainingId: LightPractice
    visualState: 1
    messages:
    - "ふーん、思ったより動けるじゃない。その調子でついてきなさい。"
  - trainingId: LightPractice
    visualState: 2
    messages:
    - "ちょっと、無理しすぎよ。倒れられたらわたしが困るんだから、息を整えなさい。"
  - trainingId: LightPractice
    visualState: 3
    messages:
    - "こ、このくらい平気よ。あんたに心配されるほど弱くないんだから。"
  - trainingId: LightPractice
    visualState: 4
    messages:
    - "二人そろって限界なんて……ふふっ、今回は引き分けにしてあげる。"
  - trainingId: SparringPractice
    visualState: 0
    messages:
    - "模擬戦だからって手加減しないわよ。あんたの実力、見せてもらうんだから。"
  - trainingId: SparringPractice
    visualState: 1
    messages:
    - "今のは悪くなかったわ。でも、次も通じると思わないことね。"
  - trainingId: SparringPractice
    visualState: 2
    messages:
    - "もう限界？　仕方ないわね……少しだけ待ってあげる。"
  - trainingId: SparringPractice
    visualState: 3
    messages:
    - "やるじゃない……でも、わたしはまだ負けてないわ。"
  - trainingId: SparringPractice
    visualState: 4
    messages:
    - "まさか同時に倒れるなんてね。つ、次こそ決着をつけるわよ。"
  - trainingId: EnduranceTraining
    visualState: 0
    messages:
    - "持久訓練は長いわよ。途中で音を上げても置いていくからね。"
  - trainingId: EnduranceTraining
    visualState: 1
    messages:
    - "まだまだこれからよ。ほら、遅れないでついてきなさい。"
  - trainingId: EnduranceTraining
    visualState: 2
    messages:
    - "顔色が悪いわよ。べ、別に心配じゃないけど、無茶は禁止。"
  - trainingId: EnduranceTraining
    visualState: 3
    messages:
    - "足が重いくらいで……ここで諦めるわけにはいかないわ。"
  - trainingId: EnduranceTraining
    visualState: 4
    messages:
    - "最後まで一緒に限界を迎えるなんて……あんたも、よく頑張ったわね。"
