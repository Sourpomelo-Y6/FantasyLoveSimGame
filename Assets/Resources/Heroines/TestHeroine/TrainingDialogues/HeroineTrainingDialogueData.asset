  heroineId: TestHeroine
  entries:
  - trainingId: LightPractice
    visualState: 0
    messages:
    - "\u3079\u3001\u5225\u306B\u3042\u3093\u305F\u306E\u6E96\u5099\u3092\u5F85\u3063\u3066\u305F\u308F\u3051\u3058\u3083\u306A\u3044\u3051\u3069\u2026\u2026\u8EFD\u3044\u7DF4\u7FD2\u304B\u3089\u59CB\u3081\u308B\u308F\u3088\u3002"
    - "\u6E96\u5099\u904B\u52D5\u304F\u3089\u3044\u3061\u3083\u3093\u3068\u3057\u306A\u3055\u3044\u3088\u306D\u3002\u3042\u3093\u305F\u304C\u602A\u6211\u3057\u305F\u3089\u3001\u7DF4\u7FD2\u306B\u306A\u3089\u306A\u3044\u3093\u3060\u304B\u3089\u3002"
  - trainingId: LightPractice
    visualState: 1
    messages:
    - "\u3075\u30FC\u3093\u3001\u601D\u3063\u305F\u3088\u308A\u52D5\u3051\u308B\u3058\u3083\u306A\u3044\u3002\u305D\u306E\u8ABF\u5B50\u3067\u3064\u3044\u3066\u304D\u306A\u3055\u3044\u3002"
    - "\u307E\u3060\u4F59\u88D5\u304C\u3042\u308A\u305D\u3046\u306D\u3002\u3079\u3001\u5225\u306B\u611F\u5FC3\u3057\u3066\u308B\u308F\u3051\u3058\u3083\u306A\u3044\u3051\u3069\u3001\u3082\u3046\u5C11\u3057\u7D9A\u3051\u308B\u308F\u3088\u3002"
  - trainingId: LightPractice
    visualState: 2
    messages:
    - "\u3061\u3087\u3063\u3068\u3001\u7121\u7406\u3057\u3059\u304E\u3088\u3002\u5012\u308C\u3089\u308C\u305F\u3089\u308F\u305F\u3057\u304C\u56F0\u308B\u3093\u3060\u304B\u3089\u3001\u606F\u3092\u6574\u3048\u306A\u3055\u3044\u3002"
    - "\u307B\u3089\u3001\u80A9\u306B\u529B\u304C\u5165\u308A\u3059\u304E\u3002\u5C11\u3057\u4F11\u3093\u3067\u304B\u3089\u3001\u3061\u3083\u3093\u3068\u308F\u305F\u3057\u306B\u3064\u3044\u3066\u304D\u306A\u3055\u3044\u3002"
  - trainingId: LightPractice
    visualState: 3
    messages:
    - "\u3053\u3001\u3053\u306E\u304F\u3089\u3044\u5E73\u6C17\u3088\u3002\u3042\u3093\u305F\u306B\u5FC3\u914D\u3055\u308C\u308B\u307B\u3069\u5F31\u304F\u306A\u3044\u3093\u3060\u304B\u3089\u3002"
    - "\u3061\u3087\u3063\u3068\u8ABF\u5B50\u3092\u5D29\u3057\u305F\u3060\u3051\u3088\u3002\u305D\u3093\u306A\u9854\u3067\u898B\u306A\u3044\u3067\u3001\u6B21\u306E\u6E96\u5099\u3092\u3057\u306A\u3055\u3044\u3002"
  - trainingId: LightPractice
    visualState: 4
    messages:
    - "\u4E8C\u4EBA\u305D\u308D\u3063\u3066\u9650\u754C\u306A\u3093\u3066\u2026\u2026\u3075\u3075\u3063\u3001\u4ECA\u56DE\u306F\u5F15\u304D\u5206\u3051\u306B\u3057\u3066\u3042\u3052\u308B\u3002"
    - "\u3042\u3093\u305F\u307E\u3067\u540C\u3058\u3068\u3053\u308D\u3067\u529B\u5C3D\u304D\u308B\u306A\u3093\u3066\u2026\u2026\u606F\u304C\u5408\u3063\u3066\u308B\u3063\u3066\u8A00\u3046\u306E\u306F\u3001\u306A\u3093\u3060\u304B\u6094\u3057\u3044\u308F\u306D\u3002"
  - trainingId: SparringPractice
    visualState: 0
    messages:
    - "\u6A21\u64EC\u6226\u3060\u304B\u3089\u3063\u3066\u624B\u52A0\u6E1B\u3057\u306A\u3044\u308F\u3088\u3002\u3042\u3093\u305F\u306E\u5B9F\u529B\u3001\u898B\u305B\u3066\u3082\u3089\u3046\u3093\u3060\u304B\u3089\u3002"
    - "\u5148\u306B\u8A00\u3063\u3066\u304A\u304F\u3051\u3069\u3001\u6CB9\u65AD\u3057\u305F\u3089\u5BB9\u8D66\u3057\u306A\u3044\u304B\u3089\u3002\u308F\u305F\u3057\u3092\u672C\u6C17\u306B\u3055\u305B\u3066\u307F\u306A\u3055\u3044\u3002"
  - trainingId: SparringPractice
    visualState: 1
    messages:
    - "\u4ECA\u306E\u306F\u60AA\u304F\u306A\u304B\u3063\u305F\u308F\u3002\u3067\u3082\u3001\u6B21\u3082\u901A\u3058\u308B\u3068\u601D\u308F\u306A\u3044\u3053\u3068\u306D\u3002"
    - "\u5C11\u3057\u306F\u69D8\u306B\u306A\u3063\u3066\u304D\u305F\u3058\u3083\u306A\u3044\u3002\u3067\u3082\u3001\u308F\u305F\u3057\u304B\u3089\u4E00\u672C\u53D6\u308B\u306B\u306F\u307E\u3060\u65E9\u3044\u308F\u3002"
  - trainingId: SparringPractice
    visualState: 2
    messages:
    - "\u3082\u3046\u9650\u754C\uFF1F\u3000\u4ED5\u65B9\u306A\u3044\u308F\u306D\u2026\u2026\u5C11\u3057\u3060\u3051\u5F85\u3063\u3066\u3042\u3052\u308B\u3002"
    - "\u8DB3\u304C\u6B62\u307E\u3063\u3066\u308B\u308F\u3088\u3002\u52DD\u8CA0\u306F\u3053\u3053\u307E\u3067\u306B\u3057\u3066\u3042\u3052\u308B\u304B\u3089\u3001\u7121\u7406\u306B\u7ACB\u3068\u3046\u3068\u3057\u306A\u3044\u3067\u3002"
  - trainingId: SparringPractice
    visualState: 3
    messages:
    - "\u3084\u308B\u3058\u3083\u306A\u3044\u2026\u2026\u3067\u3082\u3001\u308F\u305F\u3057\u306F\u307E\u3060\u8CA0\u3051\u3066\u306A\u3044\u308F\u3002"
    - "\u4ECA\u306E\u4E00\u6483\u306F\u52B9\u3044\u305F\u308F\u2026\u2026\u3061\u3087\u3063\u3068\u3001\u305D\u3053\u3067\u5F97\u610F\u305D\u3046\u306A\u9854\u3092\u3057\u306A\u3044\u3067\u3088\u306D\u3002"
  - trainingId: SparringPractice
    visualState: 4
    messages:
    - "\u307E\u3055\u304B\u540C\u6642\u306B\u5012\u308C\u308B\u306A\u3093\u3066\u306D\u3002\u3064\u3001\u6B21\u3053\u305D\u6C7A\u7740\u3092\u3064\u3051\u308B\u308F\u3088\u3002"
    - "\u76F8\u6253\u3061\u306A\u3093\u3066\u7D0D\u5F97\u3067\u304D\u306A\u3044\u308F\u3002\u4F11\u3093\u3060\u3089\u3001\u4ECA\u5EA6\u3053\u305D\u3069\u3063\u3061\u304C\u4E0A\u304B\u306F\u3063\u304D\u308A\u3055\u305B\u308B\u3093\u3060\u304B\u3089\u3002"
  - trainingId: EnduranceTraining
    visualState: 0
    messages:
    - "\u6301\u4E45\u8A13\u7DF4\u306F\u9577\u3044\u308F\u3088\u3002\u9014\u4E2D\u3067\u97F3\u3092\u4E0A\u3052\u3066\u3082\u7F6E\u3044\u3066\u3044\u304F\u304B\u3089\u306D\u3002"
    - "\u6700\u5F8C\u307E\u3067\u7D9A\u3051\u308B\u899A\u609F\u306F\u3042\u308B\uFF1F\u3000\u308F\u305F\u3057\u306E\u8DB3\u3092\u5F15\u3063\u5F35\u3063\u305F\u3089\u627F\u77E5\u3057\u306A\u3044\u308F\u3088\u3002"
  - trainingId: EnduranceTraining
    visualState: 1
    messages:
    - "\u307E\u3060\u307E\u3060\u3053\u308C\u304B\u3089\u3088\u3002\u307B\u3089\u3001\u9045\u308C\u306A\u3044\u3067\u3064\u3044\u3066\u304D\u306A\u3055\u3044\u3002"
    - "\u305D\u306E\u7A0B\u5EA6\u3067\u606F\u3092\u5207\u3089\u3057\u3066\u3069\u3046\u3059\u308B\u306E\u3002\u307B\u3089\u3001\u308F\u305F\u3057\u3068\u6B69\u8ABF\u3092\u5408\u308F\u305B\u306A\u3055\u3044\u3002"
  - trainingId: EnduranceTraining
    visualState: 2
    messages:
    - "\u9854\u8272\u304C\u60AA\u3044\u308F\u3088\u3002\u3079\u3001\u5225\u306B\u5FC3\u914D\u3058\u3083\u306A\u3044\u3051\u3069\u3001\u7121\u8336\u306F\u7981\u6B62\u3002"
    - "\u3082\u3046\u5341\u5206\u9811\u5F35\u3063\u305F\u3067\u3057\u3087\u3002\u5012\u308C\u308B\u524D\u306B\u4F11\u307F\u306A\u3055\u3044\u2026\u2026\u3053\u308C\u306F\u547D\u4EE4\u3088\u3002"
  - trainingId: EnduranceTraining
    visualState: 3
    messages:
    - "\u8DB3\u304C\u91CD\u3044\u304F\u3089\u3044\u3067\u2026\u2026\u3053\u3053\u3067\u8AE6\u3081\u308B\u308F\u3051\u306B\u306F\u3044\u304B\u306A\u3044\u308F\u3002"
    - "\u307E\u3060\u52D5\u3051\u308B\u308F\u3002\u3042\u3093\u305F\u306B\u652F\u3048\u3089\u308C\u306A\u304F\u3066\u3082\u3001\u81EA\u5206\u3067\u6700\u5F8C\u307E\u3067\u3084\u308A\u5207\u3063\u3066\u307F\u305B\u308B\u3002"
  - trainingId: EnduranceTraining
    visualState: 4
    messages:
    - "\u6700\u5F8C\u307E\u3067\u4E00\u7DD2\u306B\u9650\u754C\u3092\u8FCE\u3048\u308B\u306A\u3093\u3066\u2026\u2026\u3042\u3093\u305F\u3082\u3001\u3088\u304F\u9811\u5F35\u3063\u305F\u308F\u306D\u3002"
    - "\u4E8C\u4EBA\u3068\u3082\u7ACB\u3066\u306A\u3044\u306A\u3093\u3066\u683C\u597D\u60AA\u3044\u308F\u306D\u3002\u3067\u3082\u2026\u2026\u3042\u3093\u305F\u3068\u4E00\u7DD2\u306A\u3089\u3001\u60AA\u304F\u306A\u3044\u304B\u3082\u3002"
