--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8611759c226f4c14a090efff991731bc, type: 3}
  m_Name: HeroineTrainingDialogueData
  m_EditorClassIdentifier: 
  heroineId: TestHeroine
  entries:
  - trainingId: LightPractice
    visualState: 0
    messages:
    - "軽い練習から始めよう。準備はできてる？"
  - trainingId: LightPractice
    visualState: 1
    messages:
    - "いい調子だね。そのまま続けよう！"
  - trainingId: LightPractice
    visualState: 2
    messages:
    - "無理しすぎないで。少し呼吸を整えよう？"
  - trainingId: LightPractice
    visualState: 3
    messages:
    - "ちょっと疲れたけど、まだ大丈夫だよ。"
  - trainingId: LightPractice
    visualState: 4
    messages:
    - "二人とも夢中になりすぎたみたいだね。"
  - trainingId: SparringPractice
    visualState: 0
    messages:
    - "手加減はなしだよ。真剣に勝負しよう！"
  - trainingId: SparringPractice
    visualState: 1
    messages:
    - "今の動き、悪くなかったよ。次はもっと速く！"
  - trainingId: SparringPractice
    visualState: 2
    messages:
    - "隙あり！　でも、もう限界みたいだね。"
  - trainingId: SparringPractice
    visualState: 3
    messages:
    - "やるね……私も本気を出さないと。"
  - trainingId: SparringPractice
    visualState: 4
    messages:
    - "引き分けかな。次は絶対に負けないよ！"
  - trainingId: EnduranceTraining
    visualState: 0
    messages:
    - "長い訓練になるよ。焦らず進もうね。"
  - trainingId: EnduranceTraining
    visualState: 1
    messages:
    - "まだ半分も来てないよ。しっかりついてきて！"
  - trainingId: EnduranceTraining
    visualState: 2
    messages:
    - "あなたの頑張りは分かったから、無茶はしないで。"
  - trainingId: EnduranceTraining
    visualState: 3
    messages:
    - "足が重いけど……ここで諦めたくない。"
  - trainingId: EnduranceTraining
    visualState: 4
    messages:
    - "最後まで一緒だったね。今日はここまでにしよう。"
